# Copy this file to ".env" and fill in your own keys. The real .env is git-ignored.
# OpenDART (전자공시) API key — get one free at https://opendart.fss.or.kr
DART_API_KEY=your_opendart_key_here

# KIS Developers OpenAPI (https://apiportal.koreainvestment.com) — optional, KR+US quotes/orders
# Mock trading uses separate mock app keys issued by KIS Developers.
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT=your_account_no
KIS_MOCK=true

# Google Gemini API key (free tier ok) — optional LLM narrative/news layer
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
